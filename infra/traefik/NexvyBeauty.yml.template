# Traefik dynamic config (FILE PROVIDER) — NexvyBeauty
# Renderizado por infra/deploy-vps.sh -> /opt/stacks/traefik/dynamic/__CONTAINER__.yml
# Dominio HARDCODADO de proposito (apex nexvybeauty.com.br): 2 hosts
# (app./apex+www) derivados aqui, nao do arg DOMAIN do deploy. O gestao
# NAO vive neste dominio -> e gestao.nexvy.tech (arquivo separado).
# Motivo: passar DOMAIN=app.nexvybeauty.com.br gerava gestao.app.* / app.app.* (bug).
# So __CONTAINER__ e substituido pelo script (sed s|__CONTAINER__|$CONTAINER|g).
# Tenant e determinado por LOGIN (nao por subdominio) -> sem router wildcard.
http:
  routers:
    # NOTA (2026-07-11): gestao.nexvybeauty.com.br REMOVIDO (subdominio fantasma).
    # O gestao CANONICO e gestao.nexvy.tech (CRM do grupo), definido em
    # /opt/stacks/traefik/dynamic/nexvy-gestao-grupo.yml, apontando pro MESMO
    # container (nexvy-beauty-svc). NAO recriar gestao.nexvybeauty.com.br aqui.
    # Deploy deve usar o gate contra gestao.nexvy.tech (ou app.nexvybeauty.com.br).
    # APLICACAO (canonico): app.<dominio> -> SaaS (login, hub, super-admin)
    __CONTAINER__-app:
      rule: "Host(`app.nexvybeauty.com.br`)"
      entryPoints: [websecure]
      tls:
        certResolver: letsencrypt
      service: __CONTAINER__-svc
      middlewares: [security-headers@file, csp-nexvybeauty@file]
      priority: 110
    __CONTAINER__-app-http-redirect:
      rule: "Host(`app.nexvybeauty.com.br`)"
      entryPoints: [web]
      service: __CONTAINER__-svc
      middlewares: [redirect-to-https]
      priority: 110
    # APEX + www: marketing/funil (LP /vendas, /termos, /privacidade) — mesmo container
    __CONTAINER__-apex:
      rule: "Host(`nexvybeauty.com.br`) || Host(`www.nexvybeauty.com.br`)"
      entryPoints: [websecure]
      tls:
        certResolver: letsencrypt
      service: __CONTAINER__-svc
      middlewares: [security-headers@file, csp-nexvybeauty@file]
      priority: 100
    __CONTAINER__-http-redirect:
      rule: "Host(`nexvybeauty.com.br`) || Host(`www.nexvybeauty.com.br`)"
      entryPoints: [web]
      service: __CONTAINER__-svc
      middlewares: [redirect-to-https]
      priority: 100
  services:
    __CONTAINER__-svc:
      loadBalancer:
        servers:
          - url: "http://__CONTAINER__:80"
        passHostHeader: true
        healthCheck:
          path: "/health"
          interval: "10s"
          timeout: "3s"
          scheme: "http"
  middlewares:
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
    # CSP ISOLADO do NexvyBeauty (NÃO mexe no security-headers@file compartilhado
    # pelos outros apps). Fase atual: REPORT-ONLY — o browser reporta violações no
    # console mas NÃO bloqueia nada, para validarmos que o Meta Pixel, Supabase,
    # ViaCEP, Google Fonts e embeds seguem funcionando antes de fazer enforce.
    # Origens liberadas (inventário do runtime, 2026-07-20):
    #  script: self + inline (pixel inline no index.html + Vite) + connect.facebook.net
    #  connect: Supabase (api/wss/storage) + viacep + facebook (pixel /tr)
    #  style/font: self + inline + Google Fonts | img: https genérico (storage/qr/yt)
    #  frame-ancestors none (anti-clickjacking) + object-src none + base-uri self
    csp-nexvybeauty:
      headers:
        customResponseHeaders:
          Content-Security-Policy-Report-Only: >-
            default-src 'self';
            base-uri 'self';
            object-src 'none';
            frame-ancestors 'none';
            script-src 'self' 'unsafe-inline' https://connect.facebook.net;
            style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
            font-src 'self' data: https://fonts.gstatic.com;
            img-src 'self' data: blob: https:;
            connect-src 'self' https://*.supabase.co wss://*.supabase.co https://viacep.com.br https://www.facebook.com https://connect.facebook.net;
            frame-src 'self' https:;
            worker-src 'self' blob:
